@page "/"
@inject HttpClient Http
@inject BlazorLocalStorage LocalStorage

<div class="fawlai-container">
    @if (string.IsNullOrEmpty(CurrentUser))
    {
        <h1 class="text-center font-xl font-bold">Who is using FawlAI?</h1>
        <div class="picker-grid">
            <button class="btn-giant" @onclick='() => SelectUser("John")'>
                <span class="icon">👨‍🚒</span> John
            </button>
            <button class="btn-giant" @onclick='() => SelectUser("Marlene")'>
                <span class="icon">🚴‍♀️</span> Marlene
            </button>
        </div>
    }
    else
    {
        <div class="chat-header">
            <h2>FawlAI Concierge: @CurrentUser</h2>
            <button class="btn-small" @onclick="ClearUser">Switch Profile</button>
        </div>

        <div class="chat-history">
            @foreach (var msg in ChatMessages)
            {
                <div class="message-bubble @(msg.IsUser ? "user" : "ai")">
                    <p>@msg.Text</p>
                </div>
            }
        </div>

        <div class="input-area">
            <input @bind="CurrentQuery" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="Ask FawlAI anything..." class="input-giant" />
            <button class="btn-send" @onclick="SubmitQuery" disabled="@IsLoading">
                @(IsLoading ? "..." : "Send")
            </button>
        </div>
    }
</div>

@code {
    private string? CurrentUser { get; set; }
    private string CurrentQuery { get; set; } = string.Empty;
    private bool IsLoading { get; set; }
    private List<ChatMessage> ChatMessages { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        CurrentUser = await LocalStorage.GetItemAsync<string>("fawlai_user");
    }

    private async Task SelectUser(string name)
    {
        CurrentUser = name;
        await LocalStorage.SetItemAsync("fawlai_user", name);
    }

    private async Task ClearUser()
    {
        CurrentUser = null;
        await LocalStorage.RemoveItemAsync("fawlai_user");
        ChatMessages.Clear();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsLoading)
        {
            await SubmitQuery();
        }
    }

    private async Task SubmitQuery()
    {
        if (string.IsNullOrWhiteSpace(CurrentQuery)) return;

        IsLoading = true;
        var userPrompt = CurrentQuery;
        ChatMessages.Add(new ChatMessage { Text = userPrompt, IsUser = true });
        CurrentQuery = string.Empty;

        try
        {
            // Use dynamic base address to direct calls to the hosting Cloudflare Worker Assets host
            var requestMessage = new HttpRequestMessage(HttpMethod.Post, Http.BaseAddress);
            requestMessage.Headers.Add("X-User", CurrentUser);
            requestMessage.Content = JsonContent.Create(new { question = userPrompt });

            var response = await Http.SendAsync(requestMessage);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FawlAIResponse>();
                ChatMessages.Add(new ChatMessage { Text = result?.Response ?? "No response", IsUser = false });
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                ChatMessages.Add(new ChatMessage { Text = $"Error: {response.StatusCode} - {errorText}", IsUser = false });
            }
        }
        catch (Exception ex)
        {
            ChatMessages.Add(new ChatMessage { Text = $"Connection error: {ex.Message}", IsUser = false });
        }
        
        IsLoading = false;
    }

    public class ChatMessage { public string Text { get; set; } = string.Empty; public bool IsUser { get; set; } }
    public class FawlAIResponse { public string Response { get; set; } = string.Empty; }
}
